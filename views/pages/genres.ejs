<%- include('../partials/layout-start') %>

<header>
  <h1><%= siteName %></h1>
  <nav aria-label="Breadcrumb">
    <ol class="breadcrumb">
      <li><a href="<%= getHomePath() %>">Inventory</a></li>
      <li aria-current="page">Genres</li>
    </ol>
  </nav>
</header>
<main>
  <% if (genres.length > 0) { %>
    <ul>
      <% genres.forEach(genre => { %>
        <li><%= genre.name %></li>
      <% }); %>
    </ul>
  <% } else { %>
    <p>No genres found</p>
  <% } %>
</main>

<%- include('../partials/layout-end') %>
