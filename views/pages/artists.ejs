<%- include('../partials/layout-start') %>

<header>
  <h1><%= siteName %></h1>
  <nav aria-label="Breadcrumb">
    <ol class="breadcrumb">
      <li><a href="/">Inventory</a></li>
      <li aria-current="page">Artists</li>
    </ol>
  </nav>
</header>
<main>
  <% if (artists.length > 0) { %>
    <ul>
      <% artists.forEach(artist => { %>
        <li>
          <% const slug = artist.name.toLowerCase().replaceAll(' ', '-'); %>
          <a href="/artists/<%= artist.id %>/<%= slug %>">
            <%= artist.name %>
          </a>
        </li>
      <% }); %>
    </ul>
  <% } else { %>
    No artists found
  <% } %>
</main>

<%- include('../partials/layout-end') %>
