<dialog class="modal">
  <form
    name="delete"
    method="post"
    <% if (locals.deleteErrors?.length > 0) { %> data-invalid <% } %>
    class="modal-form"
  >
    <h2>Delete record</h2>
    <p>
      Delete <span data-context="record-name" class="record-name">record</span>?
    </p>

    <label for="admin-password">Admin password</label>
    <input type="password" name="adminPassword" id="admin-password" required />
  
    <input type="hidden" name="returnTo" />

    <% if (locals.deleteErrors?.length > 0) { %>
      <ul class="errors">
        <% deleteErrors.forEach(error => { %> <li><%= error %></li> <% }); %>
      </ul>
    <% } %>

    <div class="cancel-confirm-button-row">
      <button
        type="button"
        data-action="cancel-delete"
        class="cancel-button"
      >Cancel</button>
      <button type="submit" class="delete-submit-button">Delete record</button>
    </div>
  </form>
</dialog>
