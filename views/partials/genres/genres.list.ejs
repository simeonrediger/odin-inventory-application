<% if (genres.length > 0) { %>
  <table class="table">
    <thead>
      <tr>
        <th scope="col" class="genre-name">Genre</th>
      </tr>
    </thead>
    <tbody>
      <% genres.forEach(genre => { %>
        <tr>
          <th
            scope="row"
            class="genre-name"
            title="<%= genre.name %>"
          ><%= genre.name %></th>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } else { %>
  <p>No genres found</p>
<% } %>
